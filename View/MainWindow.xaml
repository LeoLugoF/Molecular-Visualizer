<Window x:Class="MolecularVisualizer.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:model="clr-namespace:MolecularVisualizer.Model"
        xmlns:local="clr-namespace:MolecularVisualizer.View" xmlns:viewmodel="clr-namespace:MolecularVisualizer.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Top panel -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <!-- Left panel -->
            <ColumnDefinition Width="*"/>
            <!-- Viewport -->
        </Grid.ColumnDefinitions>

        <!-- TOP PANEL (row 0, spans 2 columns) -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Background="White" >
            <Menu VerticalAlignment="Center">
                <MenuItem Header="File">
                    <MenuItem Header="Open" />
                    <MenuItem Header="Save" />
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="Settings" />
                </MenuItem>
            </Menu>

        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Background="White" >
            <Button Content="Debug Mol" Margin="10,0" Command="{Binding MoleculeVM.OnDebugMolecule}"/>
            <Button Content="Action 2"/>
        </StackPanel>

        <!-- LEFT PANEL (row 1, column 0) -->
        <StackPanel Grid.Row="2" Grid.Column="0" Width="120" Background="White" >
            <Button Content="Load Molecule" Margin="0,0,0,5" Command="{Binding SceneCommands.OnLoadedMoleculeFromFile}"/>
            <Button Content="Clear Scene" Margin="0,0,0,10" Command="{Binding MoleculeVM.OnNextMolecule}"/>
            <TreeView Name="tvMolecules" Height="300" BorderThickness="2"
                      ItemsSource="{Binding MoleculeVM.Jobs}">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type model:Job}" ItemsSource="{Binding Molecules}">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                    </HierarchicalDataTemplate>

                    <DataTemplate DataType="{x:Type model:Molecule}">
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </TreeView.Resources>

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <EventSetter Event="Selected" Handler="TreeViewItem_Selected" />
                    </Style>
                </TreeView.ItemContainerStyle>

            </TreeView>
        </StackPanel>

        <hx:Viewport3DX Grid.Row="3" Grid.Column="1"
                        x:Name="viewport" 
                        ShowViewCube="False"
                        ShowCameraTarget="False"
                        Camera="{Binding Camera}" 
                        EffectsManager="{Binding EffectsManager}"
                        CameraRotationMode="Turnball"
                        
                        EnableDeferredRendering="True"
                        EnableSharedModelMode="True"
                        MSAA="Four"
                        
                        >
            <hx:DirectionalLight3D x:Name="MainLight" Direction="0, 0, -1" Color="White" />

            <hx:ItemsModel3D ItemsSource="{Binding MoleculeVM.AtomModels}">
                <hx:ItemsModel3D.ItemTemplate>
                    <DataTemplate>
                        <hx:MeshGeometryModel3D
                            Geometry="{Binding Geometry}"
                            Material="{Binding ObjectMaterial}"
                            Transform="{Binding Transform}"/>
                    </DataTemplate>
                </hx:ItemsModel3D.ItemTemplate>
            </hx:ItemsModel3D>

            <hx:ItemsModel3D ItemsSource="{Binding MoleculeVM.BondModels}">
                <hx:ItemsModel3D.ItemTemplate>
                    <DataTemplate>
                        <hx:MeshGeometryModel3D
                            Geometry="{Binding Geometry}"
                            Material="{Binding ObjectMaterial}"
                            Transform="{Binding Transform}"/>
                    </DataTemplate>
                </hx:ItemsModel3D.ItemTemplate>
            </hx:ItemsModel3D>

        </hx:Viewport3DX>
    </Grid>
</Window>
